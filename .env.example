# .env — Desarrollo local
# Copiá este archivo como .env y ajustá los valores

REDIS_URL=redis://localhost:6379/0
CSRS_USER_EMAIL=tu@email.com
CSRS_GET_MAX=60
PPP_DIR=./ppp
# PPP_DATA_DIR=./ppp  # Railway: /app/ppp/data (montar volumen aquí)
RESULTS_DIR=/tmp/ppp_results

# Credenciales FTP IGN-Ar (para descarga automática de soluciones)
IGN_FTP_USER=<usuario FTP IGN-Ar>
IGN_FTP_PASS=<contraseña FTP IGN-Ar>

# PostgreSQL (comentado hasta que lo actives)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ppp_db
